# spendwise-agent configuration — copy to .env and fill in.
# Agent mode needs ONLY these two values:

API_URL=https://your-spendwise-api.example.com/api/v1
# Local dev is also allowed: http://127.0.0.1:5000/api/v1
BANK_AGENT_KEY=   # must match BANK_AGENT_KEY on the SpendWise server

# ─── Optional ────────────────────────────────────────────────────
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
CHROMIUM_PATH=
LOG_LEVEL=info

# ─── Standalone mode only (npm run standalone) ───────────────────
BANK_SYNC_API_KEY=
HOUSEHOLD_ID=
YAHAV_USERNAME=
YAHAV_PASSWORD=
YAHAV_NATIONAL_ID=
YAHAV_ACCOUNT_NUMBER=
HAPOALIM_USER_CODE=
HAPOALIM_PASSWORD=
LEUMI_USERNAME=
LEUMI_PASSWORD=
MIZRAHI_USERNAME=
MIZRAHI_PASSWORD=
DISCOUNT_ID=
DISCOUNT_PASSWORD=
DISCOUNT_NUM=
MERCANTILE_ID=
MERCANTILE_PASSWORD=
MERCANTILE_NUM=
OTSAR_USERNAME=
OTSAR_PASSWORD=
BEINLEUMI_USERNAME=
BEINLEUMI_PASSWORD=
MASSAD_USERNAME=
MASSAD_PASSWORD=
PAGI_USERNAME=
PAGI_PASSWORD=
ISRACARD_ID=
ISRACARD_CARD6=
ISRACARD_PASSWORD=
AMEX_ID=
AMEX_CARD6=
AMEX_PASSWORD=
VISA_CAL_USERNAME=
VISA_CAL_PASSWORD=
MAX_USERNAME=
MAX_PASSWORD=
