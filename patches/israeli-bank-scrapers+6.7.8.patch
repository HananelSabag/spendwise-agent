+// ── Balance + HTML snapshot extraction ───────────────────────────────────────
+// Called while the page is still on /main/home (BEFORE clickButton navigates
+// away to the statements view). Saves the raw portal HTML to scraped-data/ so
+// analyze-balance-html.js can find the exact selector without re-running.
+async function extractBalanceAndSnapshot(page, portfolioID) {
+  const result = await page.evaluate(() => {
+    // Balances can be negative (overdraft) and legitimately zero, so only
+    // reject non-numeric/empty — never treat 0 as "not found".
+    function parseILS(str) {
+      if (str == null) return null;
+      const cleaned = String(str).replace(/[₪\s‎‏]/g, '').replace(/,/g, '');
+      if (!/\d/.test(cleaned)) return null;
+      const n = parseFloat(cleaned);
+      return isNaN(n) ? null : n;
+    }
+
+    // Yahav BaNCS Digital does NOT expose a standalone "current balance"
+    // element. The account statement table carries a running "יתרה משוערכת"
+    // (estimated balance) as its last column, and the FIRST data row
+    // (.row.each-item) is the most recent transaction — so that row's balance
+    // cell is the current account balance. (Verified against captured portal
+    // HTML: 120-353778 → 14,632.55, 120-511509 → 12,274.84.)
+    function fromStatement() {
+      const rows = document.querySelectorAll('.row.each-item');
+      if (!rows.length) return null;
+
+      // Balance column index from the header row (cell text contains יתרה).
+      let balIdx = -1;
+      const header = document.querySelector('.row.header');
+      if (header) {
+        const cells = Array.from(header.children);
+        balIdx = cells.findIndex((c) => (c.textContent || '').includes('יתרה'));
+      }
+
+      // Scan rows top-down; the newest row with a parseable balance wins.
+      for (const row of rows) {
+        const cells = Array.from(row.children);
+        if (!cells.length) continue;
+        const cell = (balIdx >= 0 && cells[balIdx]) ? cells[balIdx] : cells[cells.length - 1];
+        const n = parseILS(cell && cell.textContent);
+        if (n !== null) return { balance: n, via: `statement-row[col=${balIdx}]` };
+      }
+      return null;
+    }
+
+    const st = fromStatement();
+    if (st) return { ...st, html: document.documentElement.outerHTML };
+
+    // Fallbacks — kept for portal variants that DO expose a balance element.
+    const selectors = [
+      'span.portfolio-balance',
+      '.portfolio-balance',
+      '.account-balance .amount',
+      '.account-balance',
+      '[class*="balance"] .amount',
+      '[class*="balance"]',
+      '.total-balance',
+      '.current-balance',
+    ];
+    for (const sel of selectors) {
+      const el = document.querySelector(sel);
+      if (el) {
+        const n = parseILS(el.textContent);
+        if (n !== null) return { balance: n, via: sel, html: document.documentElement.outerHTML };
+      }
+    }
+
+    // No match — still return full HTML so we can find the right selector offline
+    return { balance: null, via: null, html: document.documentElement.outerHTML };
+  });
+
+  // Persist HTML snapshot for offline analysis (analyze-balance-html.js)
+  try {
+    const fs = require('fs');
+    const path = require('path');
+    // Walk up from node_modules/israeli-bank-scrapers/lib/scrapers/ →
+    // lib → israeli-bank-scrapers → node_modules → repo root → scraped-data/
+    const dataDir = path.join(__dirname, '..', '..', '..', '..', 'scraped-data');
+    fs.mkdirSync(dataDir, { recursive: true });
+    const safeID = String(portfolioID).replace(/[^a-z0-9]/gi, '_');
+    fs.writeFileSync(
+      path.join(dataDir, `yahav-portal-${safeID}.html`),
+      result.html,
+      'utf8'
+    );
+  } catch (_) { /* non-fatal — snapshot is a best-effort debug aid */ }
+
+  return { balance: result.balance, via: result.via };
+}
