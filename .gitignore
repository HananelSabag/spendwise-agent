# Secrets — NEVER commit
.env
agent-private.key
.agent-device.json

# Runtime state
.agent-state.json
.worker-state.json
.agent.lock
*.log
*.log.*.bak

# Built worker executable — reproducible via worker/Build-Exe.ps1 (uses the
# C# compiler built into every Windows install, no external tools needed)
worker/*.exe
worker/build/*.generated.cs
worker/desktop/bin/
worker/desktop/obj/

# Packaged runnable copy of the worker (exe + logo + shortcuts) — a local,
# organized "app" bundle built from worker/; regenerable, not source.
Worker Windows App/
SpendWise Default Worker/

# Fully self-contained public download (exe + full agent source + its own
# node_modules) — built from source, published as a GitHub Release asset,
# never committed (its node_modules alone would be hundreds of MB).
Worker For Users/

# Scraped data (financial info stays local)
scraped-data/

# Browser profile (bank session cookies)
.chrome-profile/

# Failure screenshots (may contain bank UI)
fail-*.png

# Dependencies
node_modules/
